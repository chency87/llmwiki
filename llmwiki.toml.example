# LLMWiki Configuration Template
# Rename to llmwiki.toml to use

[paths]
# Path to your Obsidian vault
vault = "vault"

[llm]
# Provider type: openai, gemini-cli, codex-cli
provider = "openai"
# Model name (used by openai provider)
model = "gpt-4o"
# Custom API base URL
base_url = "https://api.openai.com/v1"
# api_key can be set here or via OPENAI_API_KEY environment variable
# api_key = "sk-..."

[executors]
# Commands to call for CLI agents
gemini = ["gemini"]
codex = ["codex"]

[ingest]
# Max parallel files during 'sync'
concurrency = 5
# Max parallel extractors (PDF/Image)
max_parallel_extractors = 4

[logging]
level = "INFO"
file_max_bytes = 5242880 # 5MB
file_backup_count = 5

[runtime]
# LRU cache size for page reads
read_cache_size = 128
# Seconds between background maintenance cycles
maintenance_interval_s = 3600

[dashboard]
host = "0.0.0.0"
port = 8501

[server]
# Quartz preview server settings. Quartz currently uses only the port.
host = "0.0.0.0"
port = 1313

[gateway]
enabled = false

[gateway.telegram]
# token = "..."
allowed_users = []

[gateway.rest]
enabled = false
host = "0.0.0.0"
port = 8000
# api_key = "..."

[mcp]
# Define external MCP servers
# [mcp.servers.filesystem]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/workspaces"]
